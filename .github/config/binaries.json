{
  "target_repo": "leon-ai/leon-binaries",
  "leon_repo": {
    "owner": "leon-ai",
    "name": "leon",
    "branch": "develop"
  },
  "binary_tool_mappings": {
    "pi": {
      "tool_path": "tools/coding_development/pi/tool.json",
      "tool_name": "pi"
    },
    "yt-dlp": {
      "tool_path": "tools/video_streaming/ytdlp/tool.json",
      "tool_name": "ytdlp"
    }
  },
  "binaries": [
    {
      "name": "pi",
      "source_repo": "badlogic/pi-mono",
      "asset_mappings": [
        {
          "source_pattern": "pi-linux-x64.tar.gz",
          "target_os": "linux",
          "target_arch": "x86_64",
          "target_ext": ".tar.gz"
        },
        {
          "source_pattern": "pi-linux-arm64.tar.gz",
          "target_os": "linux",
          "target_arch": "aarch64",
          "target_ext": ".tar.gz"
        },
        {
          "source_pattern": "pi-darwin-x64.tar.gz",
          "target_os": "macosx",
          "target_arch": "x86_64",
          "target_ext": ".tar.gz"
        },
        {
          "source_pattern": "pi-darwin-arm64.tar.gz",
          "target_os": "macosx",
          "target_arch": "arm64",
          "target_ext": ".tar.gz"
        },
        {
          "source_pattern": "pi-windows-x64.zip",
          "target_os": "win",
          "target_arch": "amd64",
          "target_ext": ".zip"
        }
      ]
    },
    {
      "name": "yt-dlp",
      "source_repo": "yt-dlp/yt-dlp",
      "asset_mappings": [
        {
          "source_pattern": "yt-dlp_linux",
          "target_os": "linux",
          "target_arch": "x86_64",
          "target_ext": ""
        },
        {
          "source_pattern": "yt-dlp_linux_aarch64",
          "target_os": "linux",
          "target_arch": "aarch64",
          "target_ext": ""
        },
        {
          "source_pattern": "yt-dlp_macos",
          "target_os": "macosx",
          "target_arch": "x86_64",
          "target_ext": ""
        },
        {
          "source_pattern": "yt-dlp_macos",
          "target_os": "macosx",
          "target_arch": "arm64",
          "target_ext": ""
        },
        {
          "source_pattern": "yt-dlp.exe",
          "target_os": "win",
          "target_arch": "amd64",
          "target_ext": ".exe"
        }
      ]
    }
  ]
}
